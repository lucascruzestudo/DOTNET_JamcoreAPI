# Exemplo de variáveis de ambiente — copie para .env e preencha
# NÃO commite o arquivo .env com valores reais (já está no .gitignore)

# Connection string do PostgreSQL
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=jamcore;Username=postgres;Password=CHANGE_ME

# URL do frontend (usada no CORS — pode ser múltiplos separados por vírgula)
App__FrontendUrl=https://jamcore.app

# JWT
JwtSettings__Secret=CHANGE_ME_MINIMUM_32_CHARS_STRONG_SECRET
JwtSettings__Issuer=jamcore
JwtSettings__Audience=jamcore
JwtSettings__ExpirationMinutes=60

# Redis
Redis__Connection=localhost:6379

# RabbitMQ
RabbitMQ__Connection=amqp://guest:guest@localhost:5672

# Email (Resend)
Email__ResendApiKey=CHANGE_ME
Email__ResendFromEmail=noreply@jamcore.app

# Supabase Storage
Supabase__Key=CHANGE_ME
Supabase__Url=https://CHANGE_ME.supabase.co
Supabase__Bucket=CHANGE_ME
